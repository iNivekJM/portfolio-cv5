---
export interface Props {
  profile: Record<string, any>;
  t: Record<string, any>;
}

const { profile, t } = Astro.props;
---

<section id="contact" class="py-20 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <h2 class="section-title">
        {t.contact.title}
      </h2>
      <p class="text-xl text-primary-600 dark:text-primary-400 font-medium">
        {t.contact.subtitle}
      </p>
      <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mt-4">
        {t.contact.description}
      </p>
      <div class="w-20 h-1 bg-gradient-to-r from-primary-600 to-primary-400 mx-auto rounded-full mt-6"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      <!-- Contact Info Cards -->
      <div class="space-y-4">
        <!-- Email -->
        <div class="card reveal hover:scale-105" style="transition-delay: 100ms">
          <div class="flex items-center gap-4">
            <div class="p-3 bg-primary-500/10 rounded-lg group-hover:bg-primary-500/20 transition-colors">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-sm text-gray-500 dark:text-gray-500">{t.contact.email}</p>
              <a href={`mailto:${profile.email}`} class="text-gray-900 dark:text-white font-medium hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
                {profile.email}
              </a>
            </div>
            <button
              onclick={`navigator.clipboard.writeText('${profile.email}'); const tooltip = this.querySelector('.copy-tooltip'); tooltip.classList.remove('hidden'); setTimeout(() => tooltip.classList.add('hidden'), 2000);`}
              class="p-2 text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-all hover:scale-110 relative"
              aria-label={t.contact.copyEmail}
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
              </svg>
              <span class="copy-tooltip hidden absolute -top-8 right-0 px-2 py-1 text-xs bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 rounded whitespace-nowrap shadow-lg">
                {t.contact.emailCopied}
              </span>
            </button>
          </div>
        </div>

        <!-- Phone -->
        <div class="card reveal hover:scale-105" style="transition-delay: 200ms">
          <div class="flex items-center gap-4">
            <div class="p-3 bg-primary-500/10 rounded-lg">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-sm text-gray-500 dark:text-gray-500">{t.contact.phone}</p>
              <a href={profile.phone} class="text-gray-900 dark:text-white font-medium hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
                {profile.phoneText}
              </a>
            </div>
          </div>
        </div>

        <!-- Location -->
        <div class="card reveal hover:scale-105" style="transition-delay: 300ms">
          <div class="flex items-center gap-4">
            <div class="p-3 bg-primary-500/10 rounded-lg">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-sm text-gray-500 dark:text-gray-500">{t.contact.location}</p>
              <p class="text-gray-900 dark:text-white font-medium">
                {profile.location}
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Social Links -->
      <div class="card reveal" style="transition-delay: 400ms">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-6">
          {t.contact.social}
        </h3>

        <div class="space-y-4">
          <a
            href={profile.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-4 rounded-lg bg-gray-50 dark:bg-gray-700/50 hover:bg-primary-500/10 transition-all duration-300 group hover:scale-105"
          >
            <div class="p-3 bg-[#0077B5]/10 rounded-lg group-hover:bg-[#0077B5]/20 transition-colors">
              <svg class="w-6 h-6 text-[#0077B5]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
            </div>
            <div>
              <p class="text-gray-900 dark:text-white font-medium group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                LinkedIn
              </p>
              <p class="text-sm text-gray-500 dark:text-gray-500">
                linkedin.com/in/inivekjm
              </p>
            </div>
            <svg class="w-5 h-5 text-gray-400 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors ml-auto group-hover:translate-x-1 transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>

          <a
            href={profile.github}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-4 rounded-lg bg-gray-50 dark:bg-gray-700/50 hover:bg-primary-500/10 transition-all duration-300 group hover:scale-105"
          >
            <div class="p-3 bg-gray-800/10 dark:bg-gray-600/10 rounded-lg group-hover:bg-gray-800/20 dark:group-hover:bg-gray-600/20 transition-colors">
              <svg class="w-6 h-6 text-gray-800 dark:text-gray-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.24-.726-1.085-3.259.207-3.399.582-.062 1.176.806 1.176.806 1.746-.594 3.62-.445 5.296-.445 1.676 0 3.55-.149 5.296.445 0 0 .594-.868 1.176-.806 1.293.14 1.447 2.673 1.207 3.399.77.84 1.235 1.91 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </div>
            <div>
              <p class="text-gray-900 dark:text-white font-medium group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                GitHub
              </p>
              <p class="text-sm text-gray-500 dark:text-gray-500">
                github.com/inivekjm
              </p>
            </div>
            <svg class="w-5 h-5 text-gray-400 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors ml-auto group-hover:translate-x-1 transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>
        </div>

        <!-- CTA Button -->
        <a
          href={`mailto:${profile.email}`}
          class="btn-primary w-full mt-6 justify-center group"
        >
          <svg class="w-5 h-5 mr-2 group-hover:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          {t.contact.email}
        </a>
      </div>
    </div>
  </div>
</section>
