---
export interface Props {
  projects: Record<string, any>[];
  t: Record<string, any>;
}

const { projects, t } = Astro.props;

// Sort projects by order
const sortedProjects = [...projects].sort((a, b) => a.order - b.order);
---

<section id="projects" class="py-20 bg-gray-50 dark:bg-dark-surface transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <h2 class="section-title">
        {t.projects.title}
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-primary-600 to-primary-400 mx-auto rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedProjects.map((project, index) => (
        <article
          class={`card group animate-fade-in-up overflow-hidden reveal ${!project.featured ? 'opacity-75' : ''}`}
          style={`transition-delay: ${index * 150}ms`}
        >
          <!-- Project Image -->
          <div class="relative h-48 -mx-6 -mt-6 mb-6 overflow-hidden">
            {project.image ? (
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-primary-500/20 to-primary-600/20 flex items-center justify-center group-hover:from-primary-500/30 group-hover:to-primary-600/30 transition-colors duration-500">
                <span class="text-6xl font-bold gradient-text group-hover:scale-110 transition-transform duration-500">
                  {project.title.charAt(0)}
                </span>
              </div>
            )}

            <!-- Overlay on hover -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-end justify-start p-4">
              <div class="flex gap-3 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                {project.repoUrl && (
                  <a
                    href={project.repoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="p-2.5 bg-white/20 backdrop-blur-sm rounded-full text-white hover:bg-white/30 hover:scale-110 transition-all duration-300"
                    aria-label={t.projects.repo}
                  >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.24-.726-1.085-3.259.207-3.399.582-.062 1.176.806 1.176.806 1.746-.594 3.62-.445 5.296-.445 1.676 0 3.55-.149 5.296.445 0 0 .594-.868 1.176-.806 1.293.14 1.447 2.673 1.207 3.399.77.84 1.235 1.91 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                  </a>
                )}
                {project.liveUrl && (
                  <a
                    href={project.liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="p-2.5 bg-white/20 backdrop-blur-sm rounded-full text-white hover:bg-white/30 hover:scale-110 transition-all duration-300"
                    aria-label={t.projects.live}
                  >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                  </a>
                )}
              </div>
            </div>

            <!-- Featured badge -->
            {project.featured && (
              <div class="absolute top-3 right-3 px-3 py-1 text-xs font-medium bg-primary-600 text-white rounded-full shadow-lg">
                ⭐ Featured
              </div>
            )}
          </div>

          <!-- Content -->
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
            {project.title}
          </h3>

          <p class="text-gray-600 dark:text-gray-400 text-sm mb-4 line-clamp-3">
            {project.description}
          </p>

          <!-- Technologies -->
          <div class="flex flex-wrap gap-2">
            {project.techs.map((tech: string) => (
              <span class="px-3 py-1 text-xs font-medium bg-primary-500/10 text-primary-600 dark:text-primary-400 rounded-full hover:bg-primary-500/20 transition-colors cursor-default">
                {tech}
              </span>
            ))}
          </div>

          <!-- Links (visible always on mobile) -->
          {(project.repoUrl || project.liveUrl) && (
            <div class="flex gap-3 mt-4 md:hidden">
              {project.repoUrl && (
                <a
                  href={project.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 flex items-center gap-1"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.24-.726-1.085-3.259.207-3.399.582-.062 1.176.806 1.176.806 1.746-.594 3.62-.445 5.296-.445 1.676 0 3.55-.149 5.296.445 0 0 .594-.868 1.176-.806 1.293.14 1.447 2.673 1.207 3.399.77.84 1.235 1.91 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  {t.projects.repo}
                </a>
              )}
              {project.liveUrl && (
                <a
                  href={project.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 flex items-center gap-1"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                  {t.projects.live}
                </a>
              )}
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
