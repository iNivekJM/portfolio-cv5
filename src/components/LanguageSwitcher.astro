---
export interface Props {
  currentLocale: string;
}

const { currentLocale } = Astro.props;
---

<div class="relative">
  <a
    href={currentLocale === 'es' ? '/en' : '/'}
    class="inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
    aria-label={currentLocale === 'es' ? 'Switch to English' : 'Cambiar a español'}
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/>
      <path d="M2 12h20"/>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
    </svg>
    <span class="hidden sm:inline">{currentLocale === 'es' ? 'EN' : 'ES'}</span>
  </a>
</div>
