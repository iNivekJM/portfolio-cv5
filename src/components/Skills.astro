---
export interface Props {
  skills: Record<string, any>;
  t: Record<string, any>;
}

const { skills, t } = Astro.props;
---

<section id="skills" class="py-20 bg-gray-50 dark:bg-dark-surface transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <h2 class="section-title">
        {t.skills.title}
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-primary-600 to-primary-400 mx-auto rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {skills.categories.map((category, catIndex) => (
        <div
          class="card reveal"
          style={`transition-delay: ${catIndex * 150}ms`}
        >
          <div class="flex items-center gap-3 mb-6">
            <span class="text-4xl animate-bounce" style={`animation-delay: ${catIndex * 200}ms`}>{category.icon}</span>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white">
              {category.name}
            </h3>
          </div>

          <div class="space-y-4">
            {category.skills.map((skill, skillIndex) => (
              <div>
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
                    {skill.name}
                  </span>
                  <span class="text-sm text-gray-500 dark:text-gray-500">
                    {skill.level}%
                  </span>
                </div>
                <div class="h-2.5 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                  <div
                    class="skill-bar h-full bg-gradient-to-r from-primary-600 via-primary-500 to-primary-400 rounded-full relative overflow-hidden"
                    data-width={skill.level}
                    style="width: 0; transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);"
                  >
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent animate-shimmer-bg" style="background-size: 200% 100%;"></div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Additional skills tags -->
    <div class="mt-12 text-center reveal">
      <p class="text-sm text-gray-500 dark:text-gray-500 mb-4">
        Also experienced with:
      </p>
      <div class="flex flex-wrap justify-center gap-2">
        {['Clean Code', 'SOLID Principles', 'Agile Methodologies', 'Code Review', 'Technical Mentoring', 'API Design', 'Database Design', 'Performance Optimization'].map((skill, index) => (
          <span
            class="px-4 py-2 text-sm bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-full border border-gray-200 dark:border-gray-700 hover:border-primary-500/50 hover:bg-primary-500/10 hover:text-primary-600 dark:hover:text-primary-400 hover:scale-105 transition-all duration-300 cursor-default shadow-sm hover:shadow-md"
            style={`transition-delay: ${400 + index * 50}ms`}
          >
            {skill}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes shimmer-bg {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  .animate-shimmer-bg {
    animation: shimmer-bg 2s infinite linear;
  }
</style>
