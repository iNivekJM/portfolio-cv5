---
export interface Props {
  profile: Record<string, any>;
  t: Record<string, any>;
}

const { profile, t } = Astro.props;
---

<section id="about" class="py-20 bg-gray-50 dark:bg-dark-surface transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <h2 class="section-title">
        {t.about.title}
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-primary-600 to-primary-400 mx-auto rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Image/Avatar -->
      <div class="order-2 md:order-1 reveal reveal-delay-200">
        <div class="relative group">
          <div class="absolute inset-0 bg-gradient-to-br from-primary-500 to-primary-600 rounded-2xl blur-lg opacity-30 group-hover:opacity-50 transition-opacity duration-500"></div>
          <div class="relative aspect-square rounded-2xl bg-gradient-to-br from-primary-500/20 to-primary-600/20 p-1 overflow-hidden">
            <div class="w-full h-full rounded-2xl bg-white dark:bg-gray-800 flex items-center justify-center overflow-hidden">
              <div class="text-9xl font-bold gradient-text transform group-hover:scale-110 transition-transform duration-500">
                KA
              </div>
            </div>
          </div>
          <!-- Decorative elements -->
          <div class="absolute -z-10 -top-6 -left-6 w-24 h-24 bg-primary-500/20 rounded-full blur-xl animate-pulse"></div>
          <div class="absolute -z-10 -bottom-6 -right-6 w-32 h-32 bg-primary-500/20 rounded-full blur-xl animate-pulse" style="animation-delay: 1s;"></div>
        </div>
      </div>

      <!-- Content -->
      <div class="order-1 md:order-2 reveal reveal-delay-300">
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
          {profile.name}
        </h3>
        <p class="text-primary-600 dark:text-primary-400 font-medium mb-6">
          {profile.title}
        </p>

        <div class="space-y-4 text-gray-600 dark:text-gray-400">
          <p>{profile.bio}</p>
          <p>{profile.bioExtended}</p>
        </div>

        <!-- Quick info -->
        <div class="grid grid-cols-2 gap-4 mt-8">
          <div class="flex items-center gap-3 p-4 rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:border-primary-500/30 transition-colors duration-300">
            <div class="p-2 bg-primary-500/10 rounded-lg group-hover:bg-primary-500/20">
              <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-500 dark:text-gray-500">{t.contact.email}</p>
              <a href={`mailto:${profile.email}`} class="text-sm font-medium text-gray-900 dark:text-white hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
                {profile.email}
              </a>
            </div>
          </div>
          <div class="flex items-center gap-3 p-4 rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:border-primary-500/30 transition-colors duration-300">
            <div class="p-2 bg-primary-500/10 rounded-lg">
              <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-500 dark:text-gray-500">{t.contact.location}</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">{profile.location}</p>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="flex gap-4 mt-8">
          <a href={profile.linkedin} target="_blank" rel="noopener noreferrer" class="btn-primary">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
            LinkedIn
          </a>
          <a href={profile.github} target="_blank" rel="noopener noreferrer" class="btn-secondary">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.24-.726-1.085-3.259.207-3.399.582-.062 1.176.806 1.176.806 1.746-.594 3.62-.445 5.296-.445 1.676 0 3.55-.149 5.296.445 0 0 .594-.868 1.176-.806 1.293.14 1.447 2.673 1.207 3.399.77.84 1.235 1.91 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
