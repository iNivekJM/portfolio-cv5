---
export interface Props {
  experience: Record<string, any>[];
  t: Record<string, any>;
}

const { experience, t } = Astro.props;

const formatEndDate = (endDate: string, current: boolean) => {
  return current ? t.experience.present : endDate;
};
---

<section id="experience" class="py-20 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <h2 class="section-title">
        {t.experience.title}
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-primary-600 to-primary-400 mx-auto rounded-full"></div>
    </div>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-0 md:left-1/2 transform md:-translate-x-px h-full w-0.5 bg-gradient-to-b from-primary-500 via-primary-600 to-transparent"></div>

      <div class="space-y-12">
        {experience.map((exp, index) => (
          <div class={`relative flex flex-col md:flex-row gap-8 ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
            <!-- Timeline dot -->
            <div class="absolute left-0 md:left-1/2 transform -translate-x-1/2 w-5 h-5 bg-primary-500 rounded-full border-4 border-white dark:border-dark-bg shadow-lg z-10 animate-pulse"></div>

            <!-- Content -->
            <div class={`md:w-1/2 pl-8 md:pl-0 ${index % 2 === 0 ? 'md:pl-12' : 'md:pr-12 md:text-right'} reveal`} style={`transition-delay: ${index * 150}ms`}>
              <div class="card group">
                <div class={`flex items-start justify-between mb-4 ${index % 2 === 0 ? '' : 'md:flex-row-reverse'}`}>
                  <div>
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                      {exp.role}
                    </h3>
                    <p class="text-primary-600 dark:text-primary-400 font-medium">
                      {exp.company}
                    </p>
                  </div>
                </div>

                <div class={`flex items-center gap-2 mb-4 text-sm text-gray-500 dark:text-gray-500 ${index % 2 === 0 ? '' : 'md:justify-end'}`}>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  <span>{exp.startDate} - {formatEndDate(exp.endDate, exp.current)}</span>
                </div>

                <div class={`flex items-center gap-2 mb-4 text-sm text-gray-500 dark:text-gray-500 ${index % 2 === 0 ? '' : 'md:justify-end'}`}>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  <span>{exp.location}</span>
                </div>

                <div class="space-y-3">
                  <h4 class={`font-semibold text-gray-900 dark:text-white ${index % 2 === 0 ? '' : 'md:text-right'}`}>
                    {t.experience.achievements}:
                  </h4>
                  <ul class={`space-y-2 ${index % 2 === 0 ? '' : 'md:text-left md:ml-auto md:w-fit'}`}>
                    {exp.achievements.map((achievement: string) => (
                      <li class="flex items-start gap-2 text-gray-600 dark:text-gray-400 text-sm group/item">
                        <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5 group-hover/item:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>{achievement}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- Technologies -->
                <div class={`mt-6 flex flex-wrap gap-2 ${index % 2 === 0 ? '' : 'md:justify-end'}`}>
                  {exp.technologies.map((tech: string) => (
                    <span class="px-3 py-1 text-xs font-medium bg-primary-500/10 text-primary-600 dark:text-primary-400 rounded-full hover:bg-primary-500/20 transition-colors cursor-default">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
